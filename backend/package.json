  "name": "ot-logger-backend",
  "version": "1.0.0",
  "description": "OT logging backend API (Express + Prisma + PostgreSQL)",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "postinstall": "prisma generate",
