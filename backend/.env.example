# --- Server ---
PORT=4000
# Comma-separated list of origins allowed to call the API (the web app)
CORS_ORIGIN=http://localhost:5173

# --- Database ---
# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ot_logger?schema=public"

# --- Auth ---
# Google OAuth Client ID (Web application) from Google Cloud Console.
# Must match the client id used by the web app.
GOOGLE_CLIENT_ID=648206951465-vr8tlmvtflsqidj88ugbhn4rtcekcsgm.apps.googleusercontent.com

# Secret used to sign this app's own JWT session tokens. Use a long random string.
JWT_SECRET=a7bdddbb5925ef24771d538382384fd3b19ad04a3db6bb4ca69aa9b353651c693b1ee141963346a473c6978d92f231d9
# How long a session token is valid
JWT_EXPIRES_IN=7d

# Email domains allowed to sign in (comma-separated, no @)
ALLOWED_EMAIL_DOMAINS=offspringdigital.com,artisan-labs.com

# Comma-separated list of admin emails (full access to admin endpoints)
ADMIN_EMAILS=tom@offspringdigital.com

# --- Push notifications (OneSignal) ---
# Optional: if unset, push is skipped and the app still runs.
# ONESIGNAL_APP_ID is the OneSignal App ID (UUID) — the SAME value as the app's
# EXPO_PUBLIC_ONESIGNAL_APP_ID. ONESIGNAL_KEY is the REST API Key (keep secret;
# do NOT prefix it with EXPO_PUBLIC_). Both are in OneSignal → Settings → Keys & IDs.
ONESIGNAL_APP_ID=72e79204-e5be-4c02-8898-2afa7763c76f
ONESIGNAL_KEY=os_v2_app_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Email (SMTP) ---
# Optional: if SMTP_HOST/USER/PASS are unset, email sending is skipped.
# Works with any SMTP provider (Gmail app password, SendGrid, Mailgun, etc.).
# Whether admins actually receive the "new OT" email is ALSO gated by the
# admin-configurable toggle (Admin → Settings tab on web).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@yourdomain.com
SMTP_PASS=your-smtp-password-or-app-password
SMTP_FROM="OT Tracker <you@yourdomain.com>"

# --- Teamwork integration ---
# Optional: powers OT task auto-fill (paste a Teamwork task link → fetch task info).
# If unset, GET /api/teamwork/task returns 503 and clients just skip auto-fill.
# TEAMWORK_DOMAIN is your Teamwork site host; TEAMWORK_API_TOKEN is an API key
# (Teamwork → Profile → API & Mobile → API Keys).
TEAMWORK_DOMAIN=yourcompany.teamwork.com
TEAMWORK_API_TOKEN=your-teamwork-api-token
