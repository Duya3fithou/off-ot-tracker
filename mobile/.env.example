# Base URL of the backend API (NO trailing slash, NO /api suffix — client adds /api).
#   Android emulator → http://10.0.2.2:4000
#   iOS simulator    → http://localhost:4000
#   Physical device / production → your deployed backend URL,
#                                  e.g. https://ot-logger-backend.up.railway.app
EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:4000

# Google OAuth Web client id — MUST equal backend GOOGLE_CLIENT_ID and web
# VITE_GOOGLE_CLIENT_ID (it is the ID-token audience the backend verifies).
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=648206951465-vr8tlmvtflsqidj88ugbhn4rtcekcsgm.apps.googleusercontent.com

# Google OAuth iOS client id (Google Cloud Console → Credentials → iOS type).
# The reversed form also goes into GOOGLE_IOS_URL_SCHEME at build time.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# OneSignal App ID (UUID) — optional; same value as backend ONESIGNAL_APP_ID.
# If empty, push is skipped and the app still runs.
EXPO_PUBLIC_ONESIGNAL_APP_ID=72e79204-e5be-4c02-8898-2afa7763c76f

# hot-updater OTA check-update endpoint (optional; leave empty to disable OTA).
EXPO_PUBLIC_HOT_UPDATER_SOURCE=
